# Local Supabase default after `supabase start`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Deterministic seed for the PRNG (change for different failure realizations)
SIM_SEED=20260411

# Simulation window end. Default: now. Simulation always covers 28 days ending here.
# SIM_END=2026-04-11T12:00:00Z
